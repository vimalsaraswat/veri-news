GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── Gemini model ─────────────────────────────────────────────────────────────
# Change GEMINI_MODEL to switch the model used by all three agents.
# The value is passed directly to ChatGoogleGenerativeAI(model=...).
# Common options:
#   gemini-2.0-flash              (default — fast, balanced)
#   gemini-2.5-flash-preview-04-17 (latest flash, extended thinking)
#   gemini-2.5-pro-preview-03-25   (pro, highest quality)
#   gemini-1.5-pro                 (previous pro gen)
GEMINI_MODEL=gemini-2.0-flash

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=verinews
LANGCHAIN_TRACING_V2=false
LANGSMITH_ENDPOINT=

# ── Server config ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
CACHE_TTL_SECONDS=1800
CACHE_MAX_SIZE=256
LOG_LEVEL=INFO
TAVILY_SEARCH_DAYS=30
